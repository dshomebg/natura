# Copy this file to .env and fill in real values. .env is git-ignored.

# --- PostgreSQL (Docker) ---
POSTGRES_USER=natura
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=natura
# Host port for the Dockerized Postgres (container always listens on 5432).
# Offset to 5433 to avoid clashing with the existing dshome-postgres on 5432.
POSTGRES_PORT=5433

# --- Payload / Next.js ---
# Connection string the app uses. In dev the app runs on the host, so it talks
# to Postgres via localhost:${POSTGRES_PORT}.
DATABASE_URI=postgres://natura:change-me-to-a-strong-password@localhost:5433/natura

# Long random string used by Payload to sign tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=generate-a-long-random-secret

# Public base URL of the site (used for absolute links, CORS, sitemap).
NEXT_PUBLIC_SERVER_URL=http://localhost:3100
