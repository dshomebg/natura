# Production environment for docker-compose.prod.yml.
# Copy to .env.prod on the server and fill in real values. Never commit .env.prod.

# --- PostgreSQL (internal to the compose network; not exposed to the host) ---
POSTGRES_USER=natura
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password
POSTGRES_DB=natura

# --- Payload / Next ---
# Long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=CHANGE-ME-long-random-secret
# Public URL of the site (the domain nginx serves), used for canonical/OG/sitemap.
NEXT_PUBLIC_SERVER_URL=https://natura.example.com

# --- Email notifications (optional but recommended in prod) ---
NOTIFY_EMAIL=office@natura.bg
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@natura.bg
SMTP_FROM_NAME=NATURA
